  "recomendacoes": {
    "tabela_sugerida": "icp_telemetria_snapshots",
    "proposito": "Snapshot diário/semanal de métricas ICP agregadas por período",
    "campos_chave": [
      "id (UUID PK)",
      "organizacao_id (FK)",
      "data_snapshot (DATE)",
      "lead_id, cliente_id, processo_id (references)",
      "idade_anos (calculado from data_nascimento)",
      "profissao, estado_uf, sexo, estado_civil",
      "valor_causa, valor_estimado_recuperavel, renda_mensal",
      "fase_processual, tempo_dias_caso",
      "agreement_propensity_pct, ia_success_chance_pct",
      "icp_score (composite)",
      "icp_factors (JSONB com detalhe por fator)",
      "created_at, updated_at, deleted_at"
    ],
    "rpc_sugerida": "calcular_icp_agregado(org_id, periodo_dias=90)",
    "retorna": "tabela com fator, valor_medio, count_nao_nulo, percentual_preenchimento",
    "frequencia_snapshot": "diária via n8n cron",
    "integracao_ia": "OlivIA para enriquecer campos faltantes (renda, profissao em leads)"
  },
  
